   "source": [
    "import pandas as pd\n",
    "\n",
    "data = {'ID': ['101', '102', '103', '104']}\n",
    "df = pd.DataFrame(data)\n",
    "\n",
    "print(\"Before Conversion:\")\n",
    "print(df)\n",
    "print(df.dtypes)\n",
    "print(\"\\n\")\n",
    "\n",
    "df['ID'] = df['ID'].astype(int)\n",
    "\n",
    "print(\"After Conversion:\")\n",
    "print(df)\n",
    "print(df.dtypes)\n"
   ]
  },
