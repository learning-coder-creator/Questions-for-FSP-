   ],
   "source": [
    "import pandas as pd\n",
    "\n",
    "data = {'City': ['Kolkata', 'Delhi', 'Mumbai', 'Chennai']}\n",
    "df = pd.DataFrame(data)\n",
    "\n",
    "print(\"Original DataFrame:\")\n",
    "print(df)\n",
    "print(\"\\n\")\n",
    "\n",
    "encoded_df = pd.get_dummies(df, columns=['City'], dtype=int)\n",
    "\n",
    "print(\"One-Hot Encoded DataFrame:\")\n",
    "print(encoded_df)"
   ]
  },
